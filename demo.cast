[71.625, "o", "\r\n"]
[71.625, "o", "\u001b[1;36m\u2501\u2501\u2501 Summary \u2501\u2501\u2501\u001b[0m\r\n"]
[74.125, "o", "\r\n"]
[74.125, "o", "  runc container:              \u2713 All processes visible (host eBPF)\r\n"]
[74.175, "o", "  Kata pod, no sidecar:        \u2717 Zero events\r\n"]
[74.225, "o", "  Kata pod, collector sidecar:  \u2713 All processes visible (guest eBPF)\r\n"]
[74.275, "o", "\r\n"]
[74.275, "o", "No custom kernel. No QEMU changes. No kata-agent patches.\r\n"]
[74.325, "o", "\r\n"]
