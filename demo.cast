{"version": 3, "term": {"cols": 90, "rows": 35, "type": "xterm-256color"}, "timestamp": 1783082623, "title": "RHACS eBPF Inside Kata Containers"}
[0.0, "o", "\r\n"]
[0.0, "o", "\u001b[1;36m\u2501\u2501\u2501 RHACS eBPF Inside Kata Containers \u2501\u2501\u2501\u001b[0m\r\n"]
[3.5, "o", "\r\n"]
[3.5, "o", "RHACS monitors containers via eBPF probes on the host kernel.\r\n"]
[3.6, "o", "Kata Containers run workloads in VMs with their own kernel.\r\n"]
[3.7, "o", "Can RHACS see inside a Kata VM?\r\n"]
[8.8, "o", "\r\n"]
[8.8, "o", "\u001b[1;36m\u2501\u2501\u2501 Step 1: Verify test pods are running \u2501\u2501\u2501\u001b[0m\r\n"]
